# Copiar para .env e preencher. .env nunca vai para o repositório.

DATABASE_URL=postgresql+psycopg://isaf:isaf@localhost:5432/isaf_horarios

# Caminho para o ficheiro de credenciais da service account do Firebase Admin SDK
# (nunca commitar este ficheiro — ver .gitignore). Não é exigido para RN09/RN10:
# a verificação do ID Token usa google-auth contra os certificados públicos do
# Google (ver app/core/security.py); só seria necessário para operações Admin SDK.
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# project_id do Firebase (ver frontend/lib/core/config/firebase_config.dart) —
# usado como audience na verificação do ID Token (RN09).
FIREBASE_PROJECT_ID=g-horario-b00eb

# Bootstrap do(s) primeiro(s) Superadmin(s) — não existe tabela própria; só estes
# emails podem criar Utilizador(perfil=GESTOR). Ver backend/CLAUDE.md Fase 6.
SUPERADMIN_EMAILS='["admin@isaf.co.ao"]'

# Limite de tempo (segundos) para o CP-SAT solver por job
SOLVER_MAX_TIME_SECONDS=60

ENVIRONMENT=development

# Calendário letivo — ajustar aos valores reais do ISAF antes de produção.
# SLOT_DIAS_SEMANA='["segunda","terca","quarta","quinta","sexta"]'
# SLOT_TEMPOS_POR_DIA=9
# SLOT_INICIO_PRIMEIRO_TEMPO=07:30
# SLOT_DURACAO_MINUTOS=45
