# Copiar para .env e preencher. .env nunca vai para o repositório.

DATABASE_URL=postgresql+psycopg://isaf:isaf@localhost:5432/isaf_horarios

# Caminho para o ficheiro de credenciais da service account do Firebase Admin SDK
# (nunca commitar este ficheiro — ver .gitignore)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Limite de tempo (segundos) para o CP-SAT solver por job
SOLVER_MAX_TIME_SECONDS=60

ENVIRONMENT=development

# Calendário letivo — ajustar aos valores reais do ISAF antes de produção.
# SLOT_DIAS_SEMANA='["segunda","terca","quarta","quinta","sexta"]'
# SLOT_TEMPOS_POR_DIA=9
# SLOT_INICIO_PRIMEIRO_TEMPO=07:30
# SLOT_DURACAO_MINUTOS=45
